rules_version = '2';

// SceneCraft Firestore security rules.
// Deploy with:  firebase deploy --only firestore:rules
//
// Model:
//   users/{uid}                          — user profile, tier, monthly quota counters
//   users/{uid}/state/{docId}            — singletons (e.g. activeDraftId)
//   users/{uid}/drafts/{draftId}         — saved scripts
//
// Server-only fields on users/{uid}:
//   tier, monthlyQuota, usedThisMonth, periodKey, rateMinute, rateCount,
//   lastUsageAt, stripeCustomerId, stripeSubscriptionId.
// These are written ONLY by the Vercel proxy / billing webhook via firebase-admin.
// Clients can read but not write them.

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function serverOnlyFields() {
      return ['tier','monthlyQuota','usedThisMonth','periodKey',
              'rateMinute','rateCount','lastUsageAt',
              'stripeCustomerId','stripeSubscriptionId'];
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
                    && !request.resource.data.keys().hasAny(serverOnlyFields());
      allow update: if isOwner(uid)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(serverOnlyFields());
      allow delete: if false;

      match /state/{docId} {
        allow read, write: if isOwner(uid);
      }

      match /drafts/{draftId} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
