rules_version = '2';

// SceneCraft Firestore security rules.
// Deploy with:  firebase deploy --only firestore:rules
//
// Model:
//   users/{uid}                    — user profile + monthly quota counters
//   users/{uid}/state/draft        — the user's active draft (cloud-synced)
//
// Quota fields (usedThisMonth, monthlyQuota, periodKey) are written ONLY by the
// server-side proxy via firebase-admin. Clients can read but not write them.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && !('usedThisMonth' in request.resource.data)
                    && !('monthlyQuota' in request.resource.data)
                    && !('periodKey' in request.resource.data);
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['usedThisMonth','monthlyQuota','periodKey','lastUsageAt']);
      allow delete: if false;

      match /state/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
