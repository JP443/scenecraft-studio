ANTHROPIC_API_KEY=sk-ant-...

# Firebase Admin SDK service account (JSON, on a single line).
# Get it from: Firebase Console -> Project settings -> Service accounts -> Generate new private key.
# Paste the entire JSON contents (with escaped \n in private_key) as ONE line.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}

# Optional tier overrides (tokens/month).
# FREE_TIER_QUOTA=50000
# PRO_TIER_QUOTA=2000000
# RATE_LIMIT_PER_MIN=20
